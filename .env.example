# Waystt Environment Configuration Example
# Copy this file to .env and fill in your values

# Transcription Provider Selection
# Choose between "openai" (default), "google", "local", or "parakeet"
TRANSCRIPTION_PROVIDER=openai

# OpenAI API Configuration (required when using OpenAI provider)
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI Base URL (optional - for custom API endpoints)
#OPENAI_BASE_URL=https://api.openai.com/v1

# Audio Feedback Configuration (optional - defaults shown)
ENABLE_AUDIO_FEEDBACK=true
BEEP_VOLUME=0.1

# Audio Configuration (optional - defaults shown)
AUDIO_BUFFER_DURATION_SECONDS=300
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1

# OpenAI Transcription Configuration (optional when using OpenAI)
WHISPER_MODEL=whisper-1
WHISPER_LANGUAGE=auto
WHISPER_TIMEOUT_SECONDS=60
WHISPER_MAX_RETRIES=3

# Local Whisper Configuration (when TRANSCRIPTION_PROVIDER=local)
# Model files are stored in ~/.local/share/applications/waystt/models/
# Use `waystt --download-model` to fetch the model below
#WHISPER_MODEL=ggml-base.en.bin

# Google Speech-to-Text Configuration (required when using Google provider)
# Path to your Google Cloud service account JSON credentials file
#GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json
# Primary language code (default: en-US)
#GOOGLE_SPEECH_LANGUAGE_CODE=en-US
# Speech recognition model (default: latest_long)
#GOOGLE_SPEECH_MODEL=latest_long
# Alternative language codes for automatic detection (comma-separated, max 3 total)
#GOOGLE_SPEECH_ALTERNATIVE_LANGUAGES=fr-FR,es-ES

# Parakeet Local Transcription (when TRANSCRIPTION_PROVIDER=parakeet)
# Enabled by default; disable with --no-default-features if not needed.
# Model type:
#   "ctc" - English-only, faster (batch / one-shot transcription only)
#   "tdt" - Multilingual, 25 languages (batch / one-shot transcription only)
#   "eou" - English-only, streaming with end-of-utterance detection.
#           Used automatically in continuous and daemon modes; each detected
#           utterance is emitted as a separate final string. EOU is rejected
#           on the one-shot / stop-and-transcribe path — pick ctc or tdt there.
#PARAKEET_MODEL_TYPE=ctc
# Model directory (default: ~/.local/share/applications/waystt/parakeet/{model_type}/)
# Download models from HuggingFace (place all files in the same directory):
#   CTC: https://huggingface.co/onnx-community/parakeet-ctc-0.6b-ONNX
#        files: onnx/model.onnx, onnx/model.onnx_data, tokenizer.json
#   TDT: https://huggingface.co/istupakov/parakeet-tdt-0.6b-v3-onnx
#        files: encoder-model.onnx, encoder-model.onnx.data, decoder_joint-model.onnx, vocab.txt
#   EOU: https://huggingface.co/altunenes/parakeet-rs/tree/main/realtime_eou_120m-v1-onnx
#        files: encoder.onnx, decoder_joint.onnx, tokenizer.json
#        (ONNX export of NVIDIA's parakeet_realtime_eou_120m-v1; CC-BY-4.0)
#PARAKEET_MODEL_PATH=/path/to/parakeet/model

# Logging Configuration (optional)
RUST_LOG=info